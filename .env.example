# LLM Provider — pick ONE provider block and fill in your key.
# Priority: ANTHROPIC_API_KEY > OPENAI_API_KEY+BASE_URL > OPENROUTER > GEMINI
#
# Without a key, consult_before_build and review_output return
# retrieval-only results (block matching without LLM reasoning).

# ── Innovaccer (TrueFoundry) ─────────────────────────────
# Get a service-account JWT from TrueFoundry (ask #design-mind on Slack)
OPENAI_API_KEY=<your-truefoundry-jwt>
OPENAI_BASE_URL=https://truefoundry.innovaccer.com/api/llm/api/inference/openai/
OPENAI_MODEL=internal-bedrock/sonnet-46

# ── Anthropic (direct) ───────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenRouter ────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...

# ── Gemini ────────────────────────────────────────────────
# GEMINI_API_KEY=...
